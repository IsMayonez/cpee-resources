<description xmlns="http://riddl.org/ns/description/1.0" xmlns:ann="http://riddl.org/ns/annotation/1.0" xmlns:xi="http://www.w3.org/2001/XInclude" datatypeLibrary="http://www.w3.org/2001/XMLSchema-datatypes">
  <message name="list">
    <parameter name="list" mimetype="*/xml"/>
  </message>
  <message name="exists">
    <choice>
      <parameter name="exists" mimetype="*/xml"/>
      <parameter name="exists" mimetype="text/plain"/>
    </choice>
  </message>
  <message name="testset">
    <choice>
      <parameter name="testset" mimetype="*/xml"/>
      <parameter name="exists" mimetype="text/plain"/>
    </choice>
  </message>
  <message name="symbol">
    <choice>
      <parameter name="svg" mimetype="image/svg+xml"/>
      <parameter name="exists" mimetype="text/plain"/>
    </choice>
  </message>
  <message name="schema">
    <choice>
      <parameter name="rng" mimetype="*/xml"/>
      <parameter name="exists" mimetype="text/plain"/>
    </choice>
  </message>
  <message name="json">
    <choice>
      <parameter name="json" mimetype="application/json"/>
      <parameter name="exists" mimetype="text/plain"/>
    </choice>
  </message>
  <message name="created">
    <parameter name="created" mimetype="*/xml"/>
  </message>
  <message name="updated">
    <parameter name="updated" mimetype="text/plain"/>
  </message>
  <message name="deleted">
    <parameter name="deleted" mimetype="text/plain"/>
  </message>
  <message name="error">
    <parameter name="error" mimetype="text/plain"/>
  </message>
  <message name="filedata">
    <choice>
      <parameter name="data" mimetype="image/svg+xml"/>
      <parameter name="data" mimetype="*/xml"/>
      <parameter name="data" mimetype="text/plain"/>
    </choice>
  </message>
  <message name="jsondata">
    <parameter name="data" mimetype="application/json"/>
  </message>

  <resource>
    <resource relative='modifiers'> <!--{{{-->
      <get out="list"/>
      <resource>
        <get out="list"/>
        <resource>
          <get out="exists"/>
          <resource relative="patch.xml">
            <get out="testset"/>
          </resource>
          <resource relative="unpatch.xml">
            <get out="testset"/>
          </resource>
          <resource relative="condition.json">
            <get out="json"/>
          </resource>
          <resource relative="ui.rng">
            <get out="schema"/>
          </resource>
        </resource>
      </resource>
    </resource> <!--}}}-->
    <resource relative='endpoints'>
      <get out="list"/>
      <resource>
        <get out="exists"/>
        <post out="created"/>
        <delete out="deleted"/>
        <resource relative="symbol.svg">
          <get out="symbol"/>
          <put out="updated"/>
        </resource>
        <resource relative="schema.rng">
          <get out="schema"/>
          <put out="updated"/>
        </resource>
        <resource relative="properties.json">
          <get out="json"/>
          <post in="jsondata" out="created"/>
          <put in="jsondata" out="updated"/>
          <delete out="deleted"/>
        </resource>
      </resource>
    </resource>
    <resource relative='symbols'>
      <get out="list"/>
      <resource>
        <get out="symbol"/>
        <post out="created"/>
        <put out="updated"/>
        <delete out="deleted"/>
      </resource>
    </resource>
    <resource relative='schemas'>
      <get out="list"/>
      <resource>
        <get out="schema"/>
        <post out="created"/>
        <put out="updated"/>
        <delete out="deleted"/>
      </resource>
    </resource>
  </resource>
</description>